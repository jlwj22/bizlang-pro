# BizLang Grammar (BNF/EBNF)
# ::=  defines a rule
# |    alternatives
# [ ]  optional
# { }  zero or more
# " "  literal keyword


<program>       ::= <statement> EOF

<statement>     ::= <load_stmt>
                  | <compute_stmt>
                  | <chart_stmt>
                  | <pivot_stmt>
                  | <filter_stmt>


# load
# e.g. "load sales.csv" or "load sales.csv and compute monthly revenue by region"

<load_stmt>     ::= "load" <filename> [ "and" <compute_stmt> ]

<filename>      ::= WORD "." ( "csv" | "xlsx" | "json" | "parquet" )


# compute (aggregation + groupby)
# e.g. "compute sum revenue by region"
# e.g. "compute monthly revenue by region where region is North"

<compute_stmt>  ::= "compute" [ <time_grain> ] <agg_expr> [ <time_grain> ]
                    "by" <column_list>
                    [ "where" <condition> ]

<agg_expr>      ::= [ <agg_func> ] IDENT

<agg_func>      ::= "sum" | "avg" | "count" | "min" | "max"

<time_grain>    ::= "monthly" | "daily" | "quarterly" | "yearly"


# chart
# e.g. "chart bar revenue by region"
# e.g. "generate a bar chart comparing Q1 and Q2 expenses"

<chart_stmt>    ::= "chart" [ "a" | "an" ] [ <chart_type> ] [ "chart" ]
                    ( <agg_expr> | "comparing" <column_list> [ IDENT ] )
                    [ "by" <column_list> ]

<chart_type>    ::= "bar" | "line" | "pie" | "scatter"


# pivot
# e.g. "pivot by product and region"
# e.g. "create a pivot table by product and region compute sum revenue"

<pivot_stmt>    ::= "pivot" "by" <column_list>
                    [ "and" [ "by" ] <column_list> ]
                    [ "compute" <agg_expr> ]


# filter
# e.g. "filter sales where region is North"
# e.g. "filter df where region is not South and revenue is 5000"

<filter_stmt>   ::= "filter" [ IDENT ] "where"
                    <condition> { "and" <condition> }

<condition>     ::= IDENT "is" [ "not" ] <value>

<value>         ::= STRING | NUMBER | IDENT


# shared

<column_list>   ::= IDENT { "and" IDENT }


# terminals

IDENT           ::= LETTER { LETTER | DIGIT | "_" | "-" }
STRING          ::= '"' { any char except '"' } '"'
NUMBER          ::= [ "-" ] DIGIT { DIGIT } [ "." { DIGIT } ]
FILENAME        ::= IDENT "." ( "csv" | "xlsx" | "json" | "parquet" )
EOF             ::= end of input


# Note: synonym normalization happens before lexing.
# Words like "generate", "calculate", "average", "grouped by" etc.
# are replaced with canonical keywords first. See synonyms.py.
